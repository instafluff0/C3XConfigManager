{
  "name": "civ3-c3x-modern-config-manager",
  "productName": "Civ 3 C3X Modern Configuration Manager",
  "version": "0.5.0",
  "description": "Modern config manager for C3X",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nacdobbins.c3xconfigmanager",
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor"
      }
    ]
  }
}
